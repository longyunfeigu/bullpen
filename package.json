{
  "name": "pi-ide",
  "version": "1.0.0-beta.3",
  "private": true,
  "description": "Pi-powered Agentic IDE — local-first, task-native, observable, reviewable, revertible desktop IDE",
  "license": "MIT",
  "type": "module",
  "main": "apps/desktop-main/dist/main.cjs",
  "engines": {
    "node": ">=22.19.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "check": "prettier --check . && node scripts/check-boundaries.mjs && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test --config tests/e2e/playwright.config.ts",
    "test:security": "node scripts/secret-scan.mjs --repo && vitest run --config vitest.security.config.ts && npm run build && playwright test --config tests/security/playwright.config.ts",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "package": "node scripts/package.mjs",
    "test:package:e2e": "playwright test --config tests/release/playwright.config.ts",
    "test:install:e2e": "node scripts/install-smoke.mjs",
    "release:metadata": "node scripts/release-metadata.mjs",
    "release:policy": "node scripts/release-policy.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "release:verify:quick": "node scripts/release-verify.mjs --quick",
    "postinstall": "node scripts/postinstall.mjs",
    "test:soak": "PI_IDE_SOAK=1 playwright test --config tests/e2e/playwright.config.ts tests/e2e/soak.spec.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@vscode/ripgrep": "1.18.0",
    "node-pty": "1.1.0",
    "pdfjs-dist": "6.1.200"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "esbuild": "0.28.1",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "@vscode/ripgrep@1.18.0": true,
    "electron@43.1.0": true,
    "esbuild@0.28.1": true,
    "node-pty@1.1.0": true
  },
  "overrides": {
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.7"
    },
    "@google/genai@1.52.0": {
      "protobufjs": "7.6.5"
    },
    "@mdxeditor/editor@4.0.4": {
      "js-yaml": "4.3.0"
    },
    "monaco-editor@0.55.1": {
      "dompurify": "3.4.12"
    }
  }
}
